{
    "default_route_id_enabled": true,
    "use_route_short_name_for_route_id": true,
    "default_route_long_name_enabled": true,
    "direction_finder_enabled": true,
    "trip_headsign_remove_via": true,
    "trip_headsign_cleaners": [
        {
            "regex": "( express$)",
            "ignore_case": true
        },
        {
            "regex": "((\\w+) edmonton)",
            "replacement": "$2 Edm",
            "ignore_case": true
        },
        {
            "regex": "(^(st albert center|st albert centre|st albert ctr) )",
            "ignore_case": true
        }
    ],
    "use_stop_code_for_stop_id": true,
    "stop_original_id_to_stop_id_configs": [
        {
            "original_stop_id": "A",
            "stop_id": 10000
        },
        {
            "original_stop_id": "B",
            "stop_id": 20000
        },
        {
            "original_stop_id": "C",
            "stop_id": 30000
        },
        {
            "original_stop_id": "D",
            "stop_id": 40000
        },
        {
            "original_stop_id": "E",
            "stop_id": 50000
        },
        {
            "original_stop_id": "F",
            "stop_id": 60000
        },
        {
            "original_stop_id": "G",
            "stop_id": 70000
        },
        {
            "original_stop_id": "H",
            "stop_id": 80000
        },
        {
            "original_stop_id": "I",
            "stop_id": 90000
        },
        {
            "original_stop_id": "J",
            "stop_id": 100000
        },
        {
            "original_stop_id": "K",
            "stop_id": 110000
        }
    ],
    "stop_name_cleaners": [
        {
            "regex": "(^[0-9]{4,5}\\s*-\\s*|^[A-Z]\\s*-\\s*)",
            "ignore_case": true
        },
        {
            "regex": "((\\w+) edmonton)",
            "replacement": "$2 Edm",
            "ignore_case": true
        }
    ]
}